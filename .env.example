# Copy this file to .env.development and .env.production
# and fill in your actual values

EXPO_PUBLIC_API_URL=your_api_url_here
EXPO_PUBLIC_ENVIRONMENT=development_or_production

# SSL Certificate Pinning
# The hostname of your API (no scheme, no path) e.g. api.ruralpay.com
EXPO_PUBLIC_API_DOMAIN=your_api_domain_here
# Comma-separated base64-encoded SHA-256 SPKI hashes of your cert + backup cert
# Generate with: openssl s_client -connect <host>:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform DER | openssl dgst -sha256 -binary | base64
# iOS requires at least 2 hashes (primary + backup)
EXPO_PUBLIC_SSL_PIN_HASHES=<primary_spki_hash_base64>,<backup_spki_hash_base64>
# Date after which pinning is disabled to prevent lockout if pins are not rotated (yyyy-MM-dd)
EXPO_PUBLIC_SSL_PIN_EXPIRY=2026-01-01

# NFC Card AIDs (comma-separated: name:hex_aid)
# Format: CardName:A000000004101000
EXPO_PUBLIC_NFC_CARD_AIDS=Mastercard:00A4040007A0000000041010,Visa:00A4040007A0000000031010,Maestro:00A4040007A0000000043060,Verve:00A4040007A0000000037100

# Consent version — bump this to re-prompt all existing users on next launch
EXPO_PUBLIC_CONSENT_VERSION=1.0.0